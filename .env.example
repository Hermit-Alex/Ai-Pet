# Copy this file to .env.local and fill in local-only secrets.
# Keep .env.local out of Git.

AIPET_API_KEY=
AIPET_DATA_DIR=.data
AIPET_LOGS_DIR=logs
AIPET_DEFAULT_PET_ID=cat-home
AIPET_DEFAULT_PET_NAME=猫咪
AIPET_LOG_SENSITIVE=false

# OpenClaw gateway. Leave empty to use the local safe fallback reply generator.
# For OpenClaw's /v1/chat/completions surface, enable
# gateway.http.endpoints.chatCompletions.enabled and use model openclaw/default.
AIPET_OPENCLAW_BASE_URL=
AIPET_OPENCLAW_API_KEY=
AIPET_OPENCLAW_MODEL=openclaw/default

# wxautox4 / wxauto OpenClaw WeChat channel. Keep real values in .env.local only.
AIPET_WXAUTOX4_LICENSE_KEY=
AIPET_WXAUTO_CHANNEL_ROOT=.cache/openclaw-wechat-channel
# Use .cache/wxautox-home to keep wxautox runtime state on this drive.
# Set to "default" to use the normal Windows user profile if already activated there.
AIPET_WXAUTOX_HOME=.cache/wxautox-home
AIPET_BRIDGE_URL=http://127.0.0.1:8787
AIPET_WXAPI_TOKEN=
AIPET_OPENCLAW_GATEWAY_TOKEN=

# Optional future integrations.
AIPET_HOME_ASSISTANT_URL=
AIPET_HOME_ASSISTANT_TOKEN=
AIPET_MQTT_URL=
